tch_size=batch_size,\n        shuffle=False,\n        num_workers=num_workers,\n        pin_memory=True\n    )\n \n    print(f\"\\nDataLoaders ready:\")\n    print(f\"  Train batches: {len(train_loader)}\")\n    print(f\"  Val batches:   {len(val_loader)}\")\n    print(f\"  Test batches:  {len(test_loader)}\")\n \n    return train_loader, val_loader, test_loader, class_to_idx","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-26T14:12:56.955046Z","iopub.execute_input":"2026-05-26T14:12:56.955900Z","iopub.status.idle":"2026-05-26T14:12:56.964657Z","shell.execute_reply.started":"2026-05-26T14:12:56.955868Z","shell.execute_reply":"2026-05-26T14:12:56.963655Z"}},"outputs":[],"execution_count":12},{"cell_type":"code","source":"\ndef train_alexnet(train_loader, val_loader, num_classes, num_epochs=15, learning_rate=0.0001):\n    # 1. Device configuration (use GPU if available in Kaggle)\n    device = torch.device(\"cuda:0\" if torch.cuda.is_available() else \"cpu\")\n    print(f\"Training on device: {device}\")\n\n    # 2. Load pre-trained AlexNet\n    # Using pre-trained weights gives us a massive head start on feature extraction\n    model = models.alexnet(weights=models.AlexNet_Weights.DEFAULT)\n    \n    # 3. Modify the final layer \n    # AlexNet's classifier is a Sequential block. The final layer is at index 6.\n    num_ftrs = model.classifier[6].in_features\n    model.classifier[6] = nn.Linear(num_ftrs, num_classes)\n    \n    model = model.to(device)\n\n    # 4. Define Loss and Optimizer\n    criterion = nn.CrossEntropyLoss()\n    \n    # We use a smaller learning rate because we are fine-tuning pre-existing weights\n    optimizer = optim.Adam(model.parameters(), lr=learning_rate)\n\n    # Track the best model weights to avoid saving an overfitted model\n    best_model_wts = copy.deepcopy(model.state_dict())\n    best_acc = 0.0\n\n    print(\"\\n\" + \"=\"*50)\n    print(\"STARTING TRAINING LOOP\")\n    print(\"=\"*50)\n\n    start_time = time.ti